<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hostel Details | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-100 text-slate-900">
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
      <a href="/hostels" class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-700 text-lg font-bold text-white">H</span>
        <span class="text-xl font-bold">HostelHub</span>
      </a>

      <a href="/hostels" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-700 hover:text-blue-700">
        Back to Hostels
      </a>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <% if (errorMessage) { %>
      <section class="rounded-lg border border-red-200 bg-red-50 px-6 py-10 text-center">
        <h1 class="text-xl font-bold text-red-800"><%= errorMessage %></h1>
      </section>
    <% } %>

    <% if (hostel) { %>
      <section class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-slate-200">
        <img src="<%= hostel.photoUrl %>" alt="<%= hostel.name %>" class="h-72 w-full object-cover md:h-96">

        <div class="p-5 sm:p-8">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <h1 class="text-3xl font-bold text-slate-950"><%= hostel.name %></h1>
              <p class="mt-2 text-sm leading-6 text-slate-600"><%= hostel.location %>, <%= hostel.city %></p>
            </div>

            <span class="rounded bg-emerald-100 px-3 py-1 text-sm font-bold text-emerald-700">
              Rating <%= hostel.rating || '4.8' %>
            </span>
          </div>

          <p class="mt-6 text-sm leading-7 text-slate-700"><%= hostel.description %></p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-md bg-slate-50 p-4">
              <p class="text-sm text-slate-500">Price Per Month</p>
              <p class="mt-1 text-xl font-bold text-slate-950">Rs. <%= hostel.price %></p>
            </div>

            <div class="rounded-md bg-slate-50 p-4">
              <p class="text-sm text-slate-500">Hostel Type</p>
              <p class="mt-1 text-xl font-bold text-slate-950"><%= hostel.hostelType %></p>
            </div>

            <div class="rounded-md bg-slate-50 p-4">
              <p class="text-sm text-slate-500">Rooms</p>
              <p class="mt-1 text-xl font-bold text-slate-950"><%= hostel.availableRooms %> / <%= hostel.totalRooms %></p>
            </div>

            <div class="rounded-md bg-slate-50 p-4">
              <p class="text-sm text-slate-500">Sharing Type</p>
              <p class="mt-1 text-xl font-bold text-slate-950"><%= hostel.sharingType %></p>
            </div>
          </div>

          <div class="mt-8">
            <h2 class="text-2xl font-bold text-slate-950">
              Hostel Facilities
            </h2>

            <% if (hostel.facilities && hostel.facilities.length > 0) { %>
              <div class="mt-3 flex flex-wrap gap-2">
                  <% hostel.facilities.forEach((facility) => { %> <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700 shadow-sm">
                    ✓ <%= facility %> </span>
                  <% }) %>

              </div>
            <% } else { %>
              <p class="mt-2 text-sm text-slate-600">No facilities added.</p>
            <% } %>
          </div>

            <% if (hostel.videoUrl) { %>
              <div class="mb-7">
                <h2 class="mt-3 text-lg font-bold text-slate-950">
                  Hostel Video Tour
                </h2>

                <video
                  controls
                  class="h-56 w-full rounded-lg border border-slate-200 object-cover shadow-sm"
                >
                  <source src="<%= hostel.videoUrl %>" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              </div>
            <% } %>

            <div>
              <h2 class="text-lg font-bold text-slate-950">Contact</h2>
              <p class="mt-3 text-sm text-slate-600">Phone: <span class="font-semibold text-slate-950"><%= hostel.contactNumber %></span></p>
              <% if (hostel.owner) { %>
                <p class="mt-2 text-sm text-slate-600">Owner: <span class="font-semibold text-slate-950"><%= `${hostel.owner.firstName || ''} ${hostel.owner.lastName || ''}`.trim() || hostel.owner.email %></span></p>
              <% } %>
            </div>
          </div>


        <div class="mt-8 pt-6 max-w-lg mx-auto">
          <% if (hostel.isBookedByCurrentUser) { %>
            <a href="/bookings"
              class="flex w-full items-center justify-center rounded-lg bg-blue-700 py-3 text-base font-bold text-white transition hover:bg-blue-800">
              ✓ Already Booked
            </a>
          <% } else { %>
            <a href="/bookings/confirm/<%= hostel._id %>"
             class="flex w-full items-center justify-center rounded-lg bg-blue-700 py-3 text-base font-bold text-white transition hover:bg-blue-800">
              Book Hostel Now
            </a>
          <% } %>
        </div>

        </div>
      </section>
    <% } %>
  </main>
</body>
</html>

