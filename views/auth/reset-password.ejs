<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
  <main class="grid min-h-screen lg:grid-cols-[1.05fr_0.95fr]">
    <section class="relative hidden overflow-hidden bg-slate-950 lg:block">
      <img
        src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?auto=format&fit=crop&w=1400&q=80"
        alt="Comfortable hostel bedroom"
        class="absolute inset-0 h-full w-full object-cover opacity-55"
      >
      <div class="absolute inset-0 bg-slate-950/60"></div>

      <div class="relative flex h-full flex-col justify-between p-12 text-white">
        <a href="/" class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-blue-700 text-xl font-bold">H</span>
          <span class="text-2xl font-bold">HostelHub</span>
        </a>

        <div class="max-w-xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-200">Secure reset</p>
          <h1 class="text-5xl font-bold leading-tight">Choose a new password for your account.</h1>
          <p class="mt-5 text-lg leading-8 text-slate-100">
            Reset links expire after one hour to keep your account protected.
          </p>
        </div>
      </div>
    </section>

    <section class="flex items-center justify-center px-4 py-10 sm:px-6 lg:px-12">
      <div class="w-full max-w-md">
        <div class="mb-10 flex items-center justify-between lg:hidden">
          <a href="/" class="flex items-center gap-3">
            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-700 text-lg font-bold text-white">H</span>
            <span class="text-xl font-bold">HostelHub</span>
          </a>
        </div>

        <div class="mb-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Reset password</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950">Set a fresh password</h2>
          <% if (email) { %>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Updating password for <span class="font-semibold text-slate-800"><%= email %></span>.
            </p>
          <% } else { %>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              Use a valid reset link to create a new password.
            </p>
          <% } %>
        </div>

        <% if (errors && errors.length > 0) { %>
          <div class="mb-5 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
            <%= errors[0] %>
          </div>
        <% } %>

        <% if (successMessage) { %>
          <div class="mb-5 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
            <%= successMessage %>
          </div>
        <% } %>

        <% if (token) { %>
          <form action="/auth/reset-password/<%= token %>" method="POST" class="space-y-5">
            <div>
              <label for="password" class="mb-2 block text-sm font-semibold text-slate-700">New password</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="new-password"
                required
                minlength="6"
                placeholder="At least 6 characters"
                class="h-12 w-full rounded-md border border-slate-300 bg-white px-4 text-sm outline-none transition focus:border-blue-700 focus:ring-2 focus:ring-blue-100"
              >
            </div>

            <div>
              <label for="confirmPassword" class="mb-2 block text-sm font-semibold text-slate-700">Confirm password</label>
              <input
                id="confirmPassword"
                name="confirmPassword"
                type="password"
                autocomplete="new-password"
                required
                minlength="6"
                placeholder="Repeat your new password"
                class="h-12 w-full rounded-md border border-slate-300 bg-white px-4 text-sm outline-none transition focus:border-blue-700 focus:ring-2 focus:ring-blue-100"
              >
            </div>

            <button
              type="submit"
              class="flex h-12 w-full items-center justify-center rounded-md bg-blue-700 px-5 text-sm font-bold text-white transition hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-200 focus:ring-offset-2"
            >
              Update password
            </button>
          </form>
        <% } %>

        <div class="mt-8 border-t border-slate-200 pt-6 text-center">
          <a href="/auth/login" class="text-sm font-semibold text-slate-600 hover:text-slate-950">Back to login</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>

