<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
  <main class="grid min-h-screen lg:grid-cols-[0.95fr_1.05fr]">
    <section class="relative hidden overflow-hidden bg-slate-950 lg:block">
      <img
        src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1400&q=80"
        alt="Bright hostel room"
        class="absolute inset-0 h-full w-full object-cover opacity-55"
      >
      <div class="absolute inset-0 bg-slate-950/60"></div>

      <div class="relative flex h-full flex-col justify-between p-12 text-white">
        <a href="/" class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-blue-700 text-xl font-bold">H</span>
          <span class="text-2xl font-bold">HostelHub</span>
        </a>

        <div class="max-w-xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-200">Account recovery</p>
          <h1 class="text-5xl font-bold leading-tight">Get back to your hostel plans quickly.</h1>
          <p class="mt-5 text-lg leading-8 text-slate-100">
            Enter your email and use the reset link to set a fresh password.
          </p>
        </div>
      </div>
    </section>

    <section class="flex items-center justify-center px-4 py-10 sm:px-6 lg:px-12">
      <div class="w-full max-w-md">
        <div class="mb-10 flex items-center justify-between lg:hidden">
          <a href="/" class="flex items-center gap-3">
            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-700 text-lg font-bold text-white">H</span>
            <span class="text-xl font-bold">HostelHub</span>
          </a>
        </div>

        <div class="mb-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Forgot password</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950">Reset your password</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">
            We will create a secure reset link for your HostelHub account.
          </p>
        </div>

        <% if (errors && errors.length > 0) { %>
          <div class="mb-5 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
            <%= errors[0] %>
          </div>
        <% } %>

        <% if (successMessage) { %>
          <div class="mb-5 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
            <%= successMessage %>
          </div>
        <% } %>

        <% if (resetLink) { %>
          <div class="mb-5 rounded-md border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900">
            <p class="font-semibold">Development reset link</p>
            <a href="<%= resetLink %>" class="mt-2 block break-all font-medium text-blue-700 hover:text-blue-900"><%= resetLink %></a>
          </div>
        <% } %>

        <form action="/auth/forgot-password" method="POST" class="space-y-5">
          <div>
            <label for="email" class="mb-2 block text-sm font-semibold text-slate-700">Email address</label>
            <input
              id="email"
              name="email"
              type="email"
              value="<%= oldInput.email || '' %>"
              autocomplete="email"
              required
              placeholder="you@example.com"
              class="h-12 w-full rounded-md border border-slate-300 bg-white px-4 text-sm outline-none transition focus:border-blue-700 focus:ring-2 focus:ring-blue-100"
            >
          </div>

          <button
            type="submit"
            class="flex h-12 w-full items-center justify-center rounded-md bg-blue-700 px-5 text-sm font-bold text-white transition hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-200 focus:ring-offset-2"
          >
            Create reset link
          </button>
        </form>

        <div class="mt-8 border-t border-slate-200 pt-6 text-center">
          <a href="/auth/login" class="text-sm font-semibold text-slate-600 hover:text-slate-950">Back to login</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>

