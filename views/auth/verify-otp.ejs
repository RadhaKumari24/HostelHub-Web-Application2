<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
  <main class="flex min-h-screen items-center justify-center px-4 py-10">
    <section class="w-full max-w-md rounded-lg bg-white p-8 shadow-lg">
      <a href="/" class="mb-8 flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-700 text-lg font-bold text-white">H</span>
        <span class="text-xl font-bold">HostelHub</span>
      </a>

      <div class="mb-6">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Email OTP</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-950">Verify your email</h1>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Enter the 6-digit OTP sent to your email address.
        </p>
      </div>

      <% if (errors && errors.length > 0) { %>
        <div class="mb-5 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
          <%= errors[0] %>
        </div>
      <% } %>

      <% if (successMessage) { %>
        <div class="mb-5 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-700">
          <%= successMessage %>
        </div>
      <% } %>

      <form action="/auth/verify-otp" method="POST" class="space-y-5">
        <div>
          <label for="email" class="mb-2 block text-sm font-semibold text-slate-700">Email address</label>
          <input
            id="email"
            name="email"
            type="email"
            value="<%= email || '' %>"
            autocomplete="email"
            required
            class="h-12 w-full rounded-md border border-slate-300 bg-white px-4 text-sm outline-none transition focus:border-blue-700 focus:ring-2 focus:ring-blue-100"
          >
        </div>

        <div>
          <label for="otp" class="mb-2 block text-sm font-semibold text-slate-700">OTP</label>
          <input
            id="otp"
            name="otp"
            type="text"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            autocomplete="one-time-code"
            required
            placeholder="123456"
            class="h-12 w-full rounded-md border border-slate-300 bg-white px-4 text-center text-lg font-bold tracking-widest outline-none transition focus:border-blue-700 focus:ring-2 focus:ring-blue-100"
          >
        </div>

        <button
          type="submit"
          class="flex h-12 w-full items-center justify-center rounded-md bg-blue-700 px-5 text-sm font-bold text-white transition hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-200 focus:ring-offset-2"
        >
          Verify OTP
        </button>
      </form>

      <form action="/auth/resend-otp" method="POST" class="mt-4">
        <input type="hidden" name="email" value="<%= email || '' %>">
        <button
          type="submit"
          class="flex h-11 w-full items-center justify-center rounded-md border border-slate-300 bg-white px-5 text-sm font-bold text-slate-700 transition hover:bg-slate-50"
        >
          Resend OTP
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-slate-600">
        Already verified?
        <a href="/auth/login" class="font-semibold text-blue-700 hover:text-blue-900">Login</a>
      </p>
    </section>
  </main>
</body>
</html>
