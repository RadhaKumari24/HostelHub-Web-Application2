<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <%- include("partials/sidebar") %>

    <!-- Main Content -->
    <div class="flex-1 p-8">

        <h1 class="text-3xl font-bold text-purple-700 mb-6">
            Bookings
        </h1>

        <div class="bg-white rounded-lg shadow overflow-x-auto">

            <table class="min-w-full">

                <thead class="bg-purple-700 text-white">

                    <tr>
                        <th class="px-4 py-3 text-left">Student</th>
                        <th class="px-4 py-3 text-left">Hostel</th>
                        <th class="px-4 py-3 text-left">Amount</th>
                        <th class="px-4 py-3 text-left">Payment</th>
                        <th class="px-4 py-3 text-left">Booking</th>
                        <th class="px-4 py-3 text-left">Move In</th>
                    </tr>

                </thead>

                <tbody>

                    <% bookings.forEach(booking => { %>

                    <tr class="border-b hover:bg-gray-50">

                        <td class="px-4 py-3">
                            <%= booking.studentId ? booking.studentId.firstName + " " + booking.studentId.lastName : "Deleted User" %>
                        </td>

                        <td class="px-4 py-3">
                            <%= booking.hostelId ? booking.hostelId.name : "Deleted Hostel" %>
                        </td>

                        <td class="px-4 py-3">
                            ₹<%= booking.amount %>
                        </td>

                        <td class="px-4 py-3">
                            <%= booking.paymentStatus %>
                        </td>

                        <td class="px-4 py-3">
                            <%= booking.bookingStatus %>
                        </td>

                        <td class="px-4 py-3">
                            <%= booking.moveInDate ? booking.moveInDate.toDateString() : "-" %>
                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

</body>
</html>