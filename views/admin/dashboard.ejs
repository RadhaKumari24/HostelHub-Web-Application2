<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <%- include("partials/sidebar") %>

    <!-- Main Content -->
    <div class="flex-1 p-8">

        <h1 class="text-3xl font-bold text-blue-700 mb-8">
            🏠 HostelHub Admin Dashboard
        </h1>

        <!-- Dashboard Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <div class="bg-blue-600 text-white rounded-xl shadow-lg p-6">
                <h2 class="text-lg font-semibold">👨‍🎓 Total Students</h2>
                <p class="text-4xl font-bold mt-3">
                    <%= totalStudents %>
                </p>
            </div>

            <div class="bg-green-600 text-white rounded-xl shadow-lg p-6">
                <h2 class="text-lg font-semibold">🏠 Total Owners</h2>
                <p class="text-4xl font-bold mt-3">
                    <%= totalOwners %>
                </p>
            </div>

            <div class="bg-yellow-500 text-white rounded-xl shadow-lg p-6">
                <h2 class="text-lg font-semibold">🏢 Total Hostels</h2>
                <p class="text-4xl font-bold mt-3">
                    <%= totalHostels %>
                </p>
            </div>

            <div class="bg-purple-600 text-white rounded-xl shadow-lg p-6">
                <h2 class="text-lg font-semibold">📅 Total Bookings</h2>
                <p class="text-4xl font-bold mt-3">
                    <%= totalBookings %>
                </p>
            </div>

        </div>

        <!-- Recent Bookings -->
        <div class="bg-white rounded-xl shadow-lg mt-10">

            <div class="border-b p-5">
                <h2 class="text-2xl font-bold text-gray-700">
                    📋 Recent Bookings (Last 5)
                </h2>
            </div>

            <div class="overflow-x-auto">

                <table class="min-w-full">

                    <thead class="bg-gray-100">

                        <tr>

                            <th class="px-5 py-3 text-left">Student</th>

                            <th class="px-5 py-3 text-left">Hostel</th>

                            <th class="px-5 py-3 text-left">Amount</th>

                            <th class="px-5 py-3 text-left">Status</th>

                            <th class="px-5 py-3 text-left">Move In</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% recentBookings.forEach(booking => { %>

                        <tr class="border-b hover:bg-gray-50">

                            <td class="px-5 py-3">
                                <%= booking.studentId ? booking.studentId.firstName + " " + booking.studentId.lastName : "Deleted User" %>
                            </td>

                            <td class="px-5 py-3">
                                <%= booking.hostelId ? booking.hostelId.name : "Deleted Hostel" %>
                            </td>

                            <td class="px-5 py-3">
                                ₹<%= booking.amount %>
                            </td>

                            <td class="px-5 py-3">
                                <%= booking.bookingStatus %>
                            </td>

                            <td class="px-5 py-3">
                                <%= booking.moveInDate ? booking.moveInDate.toDateString() : "-" %>
                            </td>

                        </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

</body>
</html>