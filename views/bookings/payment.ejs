<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-100 text-slate-900">
  <main class="mx-auto flex min-h-screen max-w-4xl items-center justify-center px-4 py-10">
    <section class="w-full rounded-lg bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
      <div class="mb-6">
        <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Secure Payment</p>
        <h1 class="mt-2 text-3xl font-bold text-slate-950"><%= hostel.name %></h1>
        <p class="mt-2 text-sm text-slate-600"><%= hostel.location %>, <%= hostel.city %></p>
      </div>

      <% if (errors && errors.length > 0) { %>
        <div class="mb-5 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
          <%= errors[0] %>
        </div>
      <% } %>

      <div class="mb-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm text-slate-500">Amount</p>
          <p class="mt-1 text-lg font-bold text-slate-950">Rs. <%= booking.amount %></p>
        </div>
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm text-slate-500">Booking Status</p>
          <p class="mt-1 text-lg font-bold text-slate-950"><%= booking.bookingStatus %></p>
        </div>
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm text-slate-500">Payment Status</p>
          <p class="mt-1 text-lg font-bold text-slate-950"><%= booking.paymentStatus %></p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <button id="payButton" type="button" class="inline-flex h-12 items-center justify-center rounded-md bg-blue-700 px-5 text-sm font-bold text-white transition hover:bg-blue-800">
          Pay with Razorpay
        </button>
        <a href="/hostels/details/<%= hostel._id %>" class="inline-flex h-12 items-center justify-center rounded-md border border-slate-300 bg-white px-5 text-sm font-bold text-slate-700 transition hover:border-blue-700 hover:text-blue-700">
          Back to Hostel
        </a>
      </div>

      <form id="verifyPaymentForm" action="/booking/verify-payment" method="POST" class="hidden">
        <input type="hidden" name="bookingId" value="<%= booking._id %>">
        <input type="hidden" id="razorpay_order_id" name="razorpay_order_id">
        <input type="hidden" id="razorpay_payment_id" name="razorpay_payment_id">
        <input type="hidden" id="razorpay_signature" name="razorpay_signature">
      </form>

      <form id="paymentFailureForm" action="/booking/payment-failure" method="POST" class="hidden">
        <input type="hidden" name="bookingId" value="<%= booking._id %>">
      </form>
    </section>
  </main>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    const options = {
      key: "<%= razorpayKeyId %>",
      amount: "<%= amountInPaise %>",
      currency: "INR",
      name: "HostelHub",
      description: "Hostel booking payment",
      order_id: "<%= razorpayOrderId %>",
      method: {
        upi: false,
        card: true,
        netbanking: true,
        wallet: true
      },
      prefill: {
        name: "<%= `${student.firstName || ''} ${student.lastName || ''}`.trim() %>",
        email: "<%= student.email %>"
      },
      notes: {
        bookingId: "<%= booking._id %>",
        hostelId: "<%= hostel._id %>"
      },
      handler: function (response) {
        document.getElementById("razorpay_order_id").value = response.razorpay_order_id || "";
        document.getElementById("razorpay_payment_id").value = response.razorpay_payment_id || "";
        document.getElementById("razorpay_signature").value = response.razorpay_signature || "";
        document.getElementById("verifyPaymentForm").submit();
      },
        modal: {
          ondismiss: function () {
            document.getElementById("paymentFailureForm").submit();
          }
        },
        theme: {
          color: "#1d4ed8"
        }
      };
    
      document.getElementById("payButton").addEventListener("click", function () {
        const checkout = new Razorpay(options);
        checkout.open();
      });
  </script>
</body>
</html>
