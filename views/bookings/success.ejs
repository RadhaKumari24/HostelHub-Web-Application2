<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Success | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-100 text-slate-900">
  <main class="mx-auto flex min-h-screen max-w-3xl items-center justify-center px-4 py-10">
    <section class="w-full rounded-lg bg-white p-8 text-center shadow-sm ring-1 ring-slate-200">
      <p class="text-sm font-semibold uppercase tracking-widest text-emerald-700">Payment Verified</p>
      <h1 class="mt-3 text-3xl font-bold text-slate-950">Booking Confirmed</h1>
      <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-600">
        Your payment was verified securely on the backend and your room has been reserved.
      </p>

      <div class="mt-6 grid gap-4 text-left sm:grid-cols-2">
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm text-slate-500">Hostel</p>
          <p class="mt-1 font-bold text-slate-950"><%= hostel.name %></p>
        </div>
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm text-slate-500">Payment ID</p>
          <p class="mt-1 break-words font-bold text-slate-950"><%= booking.razorpayPaymentId %></p>
        </div>
      </div>

      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/bookings" class="inline-flex h-11 items-center justify-center rounded-md bg-blue-700 px-5 text-sm font-bold text-white transition hover:bg-blue-800">
          View My Bookings
        </a>
        <a href="/hostels" class="inline-flex h-11 items-center justify-center rounded-md border border-blue-700 bg-white px-5 text-sm font-bold text-blue-700 transition hover:bg-blue-50">
          Browse Hostels
        </a>
      </div>
    </section>
  </main>
</body>
</html>
