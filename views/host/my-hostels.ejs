<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Hostels | HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="min-h-screen bg-slate-100 text-slate-900">
  <div class="flex min-h-screen">
    <aside class="hidden w-64 bg-blue-700 p-6 text-white md:block">
      <h2 class="mb-8 text-2xl font-bold">HostelHub</h2>

      <nav class="space-y-3">
        <a href="/dashboard" class="block rounded-md p-2 hover:bg-blue-600">Dashboard</a>
        <a href="/host/add" class="block rounded-md p-2 hover:bg-blue-600">Add Hostel</a>
        <a href="/host/list" class="block rounded-md bg-blue-800 p-2 font-semibold">My Hostels</a>
        <a href="/host/bookings" class="block rounded-md p-2 hover:bg-blue-600">Your Bookings</a>
      </nav>
    </aside>

    <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8">
      <div class="mb-7 flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Owner Listings</p>
          <h1 class="mt-2 text-3xl font-bold text-slate-950">My Hostels</h1>
          <p class="mt-2 text-sm text-slate-600">All hostel listings added from your owner account.</p>
        </div>

        <a href="/host/add" class="rounded-md bg-blue-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-blue-800">
          Add Hostel
        </a>
      </div>

      <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
        <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
          <%= errorMessage %>
        </div>
      <% } %>

      <% if (!hostels || hostels.length === 0) { %>
        <section class="rounded-lg border border-dashed border-slate-300 bg-white px-6 py-12 text-center">
          <h2 class="text-xl font-bold text-slate-950">No hostels listed yet</h2>
          <p class="mx-auto mt-3 max-w-md text-sm leading-6 text-slate-600">
            Add your first hostel listing so students can view room details, facilities, price, and contact information.
          </p>
          <a href="/host/add" class="mt-6 inline-flex rounded-md bg-blue-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-blue-800">
            Add New Hostel
          </a>
        </section>
      <% } else { %>
        <section class="grid gap-5 xl:grid-cols-2">
          <% hostels.forEach((hostel) => { %>
            <article class="overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-slate-200">
              <div class="grid sm:grid-cols-[210px_1fr]">
                <img
                  src="<%= hostel.photoUrl %>"
                  alt="<%= hostel.name %>"
                  class="h-56 w-full object-cover sm:h-full"
                >

                <div class="p-5">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <h2 class="text-xl font-bold text-slate-950"><%= hostel.name %></h2>
                      <p class="mt-1 text-sm text-slate-600"><%= hostel.location %>, <%= hostel.city %></p>
                    </div>

                    <span class="rounded-md bg-blue-50 px-3 py-1 text-xs font-bold text-blue-700">
                      <%= hostel.hostelType %>
                    </span>
                  </div>

                  <p class="mt-4 line-clamp-2 text-sm leading-6 text-slate-600"><%= hostel.description %></p>

                  <div class="mt-5 grid grid-cols-2 gap-3 text-sm">
                    <div class="rounded-md bg-slate-50 p-3">
                      <p class="text-slate-500">Price / Month</p>
                      <p class="mt-1 font-bold text-slate-950">Rs. <%= hostel.price %></p>
                    </div>

                    <div class="rounded-md bg-slate-50 p-3">
                      <p class="text-slate-500">Rooms</p>
                      <p class="mt-1 font-bold text-slate-950"><%= hostel.availableRooms %> / <%= hostel.totalRooms %> available</p>
                    </div>

                    <div class="rounded-md bg-slate-50 p-3">
                      <p class="text-slate-500">Sharing</p>
                      <p class="mt-1 font-bold text-slate-950"><%= hostel.sharingType %></p>
                    </div>

                    <div class="rounded-md bg-slate-50 p-3">
                      <p class="text-slate-500">Contact</p>
                      <p class="mt-1 font-bold text-slate-950"><%= hostel.contactNumber %></p>
                    </div>
                  </div>

                  <% if (hostel.facilities && hostel.facilities.length > 0) { %>
                    <div class="mt-4 flex flex-wrap gap-2">
                      <% hostel.facilities.forEach((facility) => { %>
                        <span class="rounded-md border border-slate-200 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= facility %></span>
                      <% }) %>
                    </div>
                  <% } %>

                  <div class="mt-5 flex flex-wrap gap-3 border-t border-slate-200 pt-4">
                    <a href="/host/details/<%= hostel._id %>" class="inline-flex h-10 items-center justify-center rounded-md bg-blue-700 px-4 text-sm font-bold text-white transition hover:bg-blue-800">
                      Details
                    </a>
                    <a href="/host/edit/<%= hostel._id %>" class="inline-flex h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-4 text-sm font-bold text-slate-700 transition hover:border-blue-700 hover:text-blue-700">
                      Edit
                    </a>
                  </div>
                </div>
              </div>
            </article>
          <% }) %>
        </section>
      <% } %>
    </main>
  </div>
</body>
</html>

