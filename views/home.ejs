<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HostelHub</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="bg-slate-50 text-slate-900">
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
      <a href="/" class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-700 text-lg font-bold text-white">H</span>
        <span class="text-xl font-bold tracking-normal">HostelHub</span>
      </a>

      <nav class="hidden items-center gap-8 text-sm font-medium text-slate-600 md:flex">
        <a href="#hostels" class="hover:text-blue-700">Hostels</a>
        <a href="#cities" class="hover:text-blue-700">Cities</a>
        <a href="#support" class="hover:text-blue-700">Support</a>
        <% if (isLoggedIn) { %>
          <a href="<%= user.userType === 'student' ? '/hostels' : '/dashboard' %>" class="hover:text-blue-700">User Dashboard</a>
        <% } %>
      </nav>

      <div class="flex items-center gap-3">
        <% if (!isLoggedIn) { %>
          <a href="/auth/login" class="rounded-md px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">Login</a>
          <a href="/auth/signup" class="rounded-md bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">Signup</a>
        <% } else { %>
          <span class="hidden text-sm font-medium text-slate-600 sm:inline">Hi, <%= user.firstName %></span>
          <a href="<%= user.userType === 'student' ? '/hostels' : '/dashboard' %>" class="rounded-md bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800"><%= user.userType === 'student' ? 'Browse Hostels' : 'Dashboard' %></a>
        <% } %>
      </div>
    </div>
  </header>

  <main>
    <section class="relative overflow-hidden bg-slate-950">
      <img
        src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?auto=format&fit=crop&w=1800&q=80"
        alt="Modern hostel common area"
        class="absolute inset-0 h-full w-full object-cover opacity-45"
      >
      <div class="absolute inset-0 bg-slate-950/45"></div>

      <div class="relative mx-auto grid min-h-[620px] max-w-7xl content-center gap-8 px-4 py-16 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-cyan-200">Student stays made simpler</p>
          <h1 class="text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl">
            HostelHub
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-100">
            Find verified hostels, compare rooms, and manage your stay from one clean dashboard.
          </p>
        </div>

        <form action="<%= isLoggedIn ? (user.userType === 'student' ? '/hostels' : '/dashboard') : '/auth/login' %>" method="GET" class="grid max-w-5xl gap-3 rounded-lg bg-white p-3 shadow-2xl md:grid-cols-[1.3fr_1fr_auto]">
          <label class="block">
            <span class="sr-only">Location</span>
            <input
              name="city"
              type="text"
              placeholder="Search by city"
              class="h-12 w-full rounded-md border border-slate-200 px-4 text-sm outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-100"
            >
          </label>

          <label class="block">
            <span class="sr-only">Budget</span>
            <select name="maxPrice" class="h-12 w-full rounded-md border border-slate-200 px-4 text-sm outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-100">
              <option value="">Budget range</option>
              <option value="5000">Under Rs. 5,000</option>
              <option value="10000">Under Rs. 10,000</option>
              <option value="15000">Under Rs. 15,000</option>
            </select>
          </label>

          <button type="submit" class="h-12 rounded-md bg-blue-700 px-6 text-sm font-semibold text-white hover:bg-blue-800">
            Search
          </button>
        </form>
      </div>
    </section>

    <section id="hostels" class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
      <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-blue-700">Popular spaces</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950">Featured hostels</h2>
        </div>
        <% if (isLoggedIn) { %>
          <a href="<%= user.userType === 'student' ? '/hostels' : '/dashboard' %>" class="text-sm font-semibold text-blue-700 hover:text-blue-900"><%= user.userType === 'student' ? 'Browse all hostels' : 'Open dashboard' %></a>
        <% } else { %>
          <a href="/auth/login" class="text-sm font-semibold text-blue-700 hover:text-blue-900">Login to browse</a>
        <% } %>
      </div>

      <% if (errorMessage) { %>
        <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
          <%= errorMessage %>
        </div>
      <% } %>

      <% if (!hostels || hostels.length === 0) { %>
        <div class="rounded-lg border border-dashed border-slate-300 bg-white px-6 py-12 text-center">
          <h3 class="text-xl font-bold text-slate-950">No hostels listed yet</h3>
          <p class="mx-auto mt-3 max-w-md text-sm leading-6 text-slate-600">
            Owner listings will appear here as soon as hostels are added.
          </p>
        </div>
      <% } else { %>
        <div class="grid gap-6 md:grid-cols-3">
          <% hostels.forEach((hostel) => { %>
            <article class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
              <img src="<%= hostel.photoUrl %>" alt="<%= hostel.name %>" class="h-52 w-full object-cover">

              <div class="p-5">
                <div class="mb-3 flex items-center justify-between gap-3">
                  <h3 class="font-bold text-slate-950"><%= hostel.name %></h3>
                  <span class="rounded bg-emerald-100 px-2 py-1 text-xs font-semibold text-emerald-700"><%= hostel.rating || '4.8' %></span>
                </div>

                <div class="mt-4 flex items-center justify-between gap-3">
                  <p class="font-bold text-slate-950">
                    Rs. <%= hostel.price %>
                    <span class="text-sm font-normal text-slate-500">/ month</span>
                  </p>
                </div>

                <div class="mt-5 flex flex-wrap gap-3">
                  <a href="<%= isLoggedIn ? '/hostels/details/' + hostel._id : '/auth/login' %>" class="inline-flex h-10 items-center justify-center rounded-md bg-blue-700 px-4 text-sm font-bold text-white transition hover:bg-blue-800">
                    View Details
                  </a>
                  <a href="<%= isLoggedIn ? '/hostels/details/' + hostel._id : '/auth/login' %>" class="inline-flex h-10 items-center justify-center rounded-md border border-blue-700 bg-white px-4 text-sm font-bold text-blue-700 transition hover:bg-blue-50">
                    Book Now
                  </a>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section id="cities" class="border-y border-slate-200 bg-white">
      <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-4 lg:px-8">
        <div>
          <p class="text-3xl font-bold text-slate-950"><%= hostels ? hostels.length : 0 %></p>
          <p class="mt-1 text-sm text-slate-600">Listed hostels</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-slate-950">18</p>
          <p class="mt-1 text-sm text-slate-600">Active cities</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-slate-950">4.7</p>
          <p class="mt-1 text-sm text-slate-600">Average rating</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-slate-950">24/7</p>
          <p class="mt-1 text-sm text-slate-600">Account access</p>
        </div>
      </div>
    </section>
  </main>

  <footer id="support" class="bg-slate-950 px-4 py-8 text-slate-300 sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-7xl flex-col justify-between gap-4 sm:flex-row sm:items-center">
      <p class="text-sm">HostelHub</p>
      <% if (isLoggedIn) { %>
        <form action="/auth/logout" method="POST">
          <button type="submit" class="text-sm font-semibold text-white hover:text-cyan-200">Logout</button>
        </form>
      <% } else { %>
        <div class="flex gap-5 text-sm">
          <a href="/auth/login" class="hover:text-white">Login</a>
          <a href="/auth/signup" class="hover:text-white">Signup</a>
        </div>
      <% } %>
    </div>
  </footer>
</body>
</html>

